# 12-factor §3 — Config lives in the environment, never in the repo.
# Copy this file to .env for local development. In production (Digital Ocean
# App Platform) these are supplied by the platform / the managed database /
# secret env bindings.

# ───────────────── Core ─────────────────
PORT=3000
NODE_ENV=development

# Digital Ocean Managed PostgreSQL 18 connection string.
DATABASE_URL=postgres://bikeheadz:bikeheadz@localhost:5432/bikeheadz

# Set to "false" only for local plaintext Postgres. DO managed DB requires TLS.
DATABASE_SSL=false

# Optional tuning.
DB_POOL_MAX=10
LOG_LEVEL=info

# CORS origin for the socket.io server. Use "true" to echo request origin.
CORS_ORIGIN=true

# Public URL used for Stripe success/cancel redirects, magic-link emails, etc.
APP_URL=http://localhost:5173

# ───────────────── Auth (P1-001 / P1-002) ─────────────────
# 32+ byte random string. REQUIRED in production. In dev/test we fall back
# to a hard-coded dev secret with a warning so the loop works zero-config.
AUTH_SECRET=

# Cookie name + max age (seconds). Defaults: bh_session, 30 days.
AUTH_COOKIE_NAME=bh_session
AUTH_COOKIE_MAX_AGE_S=2592000

# Magic-link token TTL (ms). Defaults to 15 minutes.
AUTH_TOKEN_TTL_MS=900000

# Comma-separated emails to seed as admin role on first sign-in (P0-008).
ADMIN_EMAILS=

# ───────────────── Email (P1-001 / P2-008) ─────────────────
# Provider: set ONE of RESEND_API_KEY or POSTMARK_TOKEN. With neither, the
# server logs the rendered email body to stdout — fine for dev.
EMAIL_FROM=BikeHeadz <noreply@bikeheadz.test>
RESEND_API_KEY=
POSTMARK_TOKEN=
POSTMARK_STREAM=outbound

# ───────────────── Rate limiting (P0-006) ─────────────────
STL_RATE_LIMIT_PER_SOCKET=3
STL_RATE_LIMIT_PER_IP=10
AUTH_LIMIT_PER_EMAIL=3
AUTH_LIMIT_PER_IP=10

# Image cap on uploads (bytes). Defaults to 5 MB.
MAX_IMAGE_BYTES=5242880

# ───────────────── Sentry (P0-005) ─────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Bearer token for /metrics (P4-002). Empty = no auth required.
METRICS_TOKEN=

# ───────────────── TRELLIS (photo → 3D head) ─────────────────
TRELLIS_PATH=./TRELLIS-main
TRELLIS_MODEL=microsoft/TRELLIS-image-large
TRELLIS_DEVICE=cuda
TRELLIS_ENABLED=true
PYTHON_BIN=python3

# ───────────────── RunPod (GPU TRELLIS backend) ─────────────────
RUNPOD_ENDPOINT_URL=
RUNPOD_API_KEY=

# ───────────────── Stripe (checkout) ─────────────────
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd

# Per-product prices in cents.
STRIPE_PRICE_STL_CENTS=200
STRIPE_PRICE_PRINT_CENTS=1999
STRIPE_PRICE_PACK_CENTS=5999

# P2-001 — Stripe webhook for payment durability.
STRIPE_WEBHOOK_ENABLED=false
STRIPE_WEBHOOK_SECRET=

# P2-006 — automatic_tax (requires Stripe Tax registration in dashboard).
STRIPE_TAX_ENABLED=false

# P2-003 — comma-separated ISO country codes for shipping_address_collection.
STRIPE_SHIPPING_COUNTRIES=US,CA,GB,DE,FR,IE,NL,BE,IT,ES,DK,SE,NO,FI,AU,NZ

# P2-015 — Stripe Customer Portal config id (test/live separation).
STRIPE_CUSTOMER_PORTAL_CONFIG_ID=

# ───────────────── Feature flags (P0-010) ─────────────────
# Each flag is overridable as FLAG_<KEY>=true|false|<percent>.
# Examples:
#   FLAG_BEST_OF_N=false
#   FLAG_LIVE_REDLINE=10        # 10% rollout

# ───────────────── Vite dev server ─────────────────
VITE_PORT=5173
BACKEND_PORT=3000

# ───────────────── Share links (P5-002) ─────────────────
SHARE_LINK_SECRET=

# ───────────────── Pipeline timeouts (P0-017) + size cap (P0-018) ─────────
# Honoured by handler.py / pipeline/__init__.py.
STAGE_TIMEOUT_S=60
JOB_TIMEOUT_S=300
MAX_TRIS_AFTER_REPAIR=500000

# ───────────────── Synthetic canary (P4-013) ─────────────────
CANARY_TIMEOUT_MS=300000
CANARY_LATENCY_BUDGET_MS=90000
CANARY_MIN_BYTES=200000
CANARY_MAX_BYTES=10000000
CANARY_TOKEN=
