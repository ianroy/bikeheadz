# 12-factor §3 — Config lives in the environment, never in the repo.
# Copy this file to .env for local development. In production (Digital Ocean
# App Platform) these are supplied by the platform / the managed database /
# secret env bindings.

# ───────────────── Core ─────────────────
PORT=3000
NODE_ENV=development

# Digital Ocean Managed PostgreSQL 18 connection string.
# DO provides this automatically when a DB component is attached.
# Locally you can point it at a local Postgres instance.
DATABASE_URL=postgres://bikeheadz:bikeheadz@localhost:5432/bikeheadz

# Set to "false" only for local plaintext Postgres. DO managed DB requires TLS.
DATABASE_SSL=false

# Optional tuning.
DB_POOL_MAX=10
LOG_LEVEL=info

# CORS origin for the socket.io server. Use "true" to echo request origin.
CORS_ORIGIN=true

# Public URL used for Stripe success/cancel redirects and absolute links.
# In production this is your DO App URL (https://bikeheadz-xxxxx.ondigitalocean.app).
APP_URL=http://localhost:5173

# ───────────────── TRELLIS (photo → 3D head) ─────────────────
# Path to the cloned Microsoft/TRELLIS repo. Empty uses system-installed
# `trellis` package (from `pip install -e .`).
TRELLIS_PATH=./TRELLIS-main

# Hugging Face model id. Default is the official image-conditioned large model.
TRELLIS_MODEL=microsoft/TRELLIS-image-large

# cuda | cpu. TRELLIS is effectively GPU-only — cpu mode will time out.
TRELLIS_DEVICE=cuda

# Set to "false" to bypass TRELLIS entirely and use a procedural fallback
# head. Useful for CI and dev machines without a GPU.
TRELLIS_ENABLED=true

# Python interpreter used to spawn the worker.
PYTHON_BIN=python3

# ───────────────── Stripe (checkout) ─────────────────
# Test keys start with sk_test_ / pk_test_. Never commit live keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# Prices in cents. Defaults to $2 / $19.99 / $59.99.
STRIPE_PRICE_STL_CENTS=200
STRIPE_PRICE_PRINT_CENTS=1999
STRIPE_PRICE_PACK4_CENTS=5999

# ───────────────── Vite dev server ─────────────────
VITE_PORT=5173
BACKEND_PORT=3000
