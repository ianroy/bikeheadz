{
  "name": "valveheadz",
  "private": true,
  "version": "1.0.0",
  "description": "3D bike valve stem personalization app — SVG.js frontend, socket.io command-pattern backend, Postgres 18.",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch --env-file=.env server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "migrate": "node server/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml,html,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/browser": "^8.42.0",
    "@sentry/node": "^8.42.0",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@svgdotjs/svg.js": "^3.2.4",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^17.5.0",
    "three": "^0.171.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.1.12",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.12",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  }
}
