{
  "name": "bikeheadz",
  "private": true,
  "version": "1.0.0",
  "description": "3D bike valve stem personalization app — SVG.js frontend, socket.io command-pattern backend, Postgres 18.",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch --env-file=.env server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "migrate": "node server/migrate.js"
  },
  "dependencies": {
    "@svgdotjs/svg.js": "^3.2.4",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^17.5.0",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.12",
    "vite": "^6.3.5"
  }
}
